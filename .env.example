# Supabase — obtenha em https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL pública da aplicação — usado no emailRedirectTo do signup
# Em desenvolvimento: http://localhost:3000
# Em produção: https://seu-dominio.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Service Role Key — bypassa RLS, use apenas no servidor
# Obtenha em: Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Web Push (notificações push) — gere com: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@seudominio.com

# Secret para autenticar chamadas do cron job de notificações
# Use uma string aleatória longa: openssl rand -hex 32
CRON_SECRET=
